generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id @default(uuid())
  date        String
  description String
  amount      Float
  category    String
  createdAt   DateTime @default(now())
}

model ClassificationCache {
  id          String @id @default(uuid())
  description String @unique
  category    String
}